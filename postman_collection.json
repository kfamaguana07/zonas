          "name": "11. Desactivar zona REGULAR (debe funcionar si no tiene espacios)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 204) {",
                  "    pm.collectionVariables.set('idZonaInactiva', pm.collectionVariables.get('idZonaREG'));",
                  "    console.log('idZonaREG ahora es inactiva');",
                  "}"
                ],
